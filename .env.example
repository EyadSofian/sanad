# ===== LLM =====
# Voice transcription still needs Gemini. Text chat can run on OpenAI/Anthropic.
GEMINI_API_KEY=

# Text engine — gemini (default) | openai | anthropic
LLM_PROVIDER=gemini
# OpenAI (used when LLM_PROVIDER=openai). Cost-friendly default: gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
# Anthropic / Claude (used when LLM_PROVIDER=anthropic). Default model: claude-opus-4-8
# Cheaper options: claude-sonnet-5, claude-haiku-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Embeddings for KB/memory — gemini | openai. OpenAI uses 768 dimensions to match pgvector schema.
EMBEDDING_PROVIDER=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# ===== TTS (ElevenLabs) =====
ELEVENLABS_API_KEY=
ELEVEN_VOICE_ID=
# 10,000 credits total; eleven_flash_v2_5 = 0.5 credits/char (~20,000 chars)
TTS_CREDIT_BUDGET=10000

# ===== Core =====
DATABASE_URL=postgresql://postgres:password@localhost:5432/sanad
JWT_SECRET=change-me-to-a-long-random-string
METRICS_HMAC_SECRET=change-me-shared-with-n8n
NODE_ENV=development
PORT=8080

# ===== Safety =====
# JSON overriding config/crisis-resources.default.json — VERIFY numbers before launch (Section 0 checklist)
CRISIS_RESOURCES_JSON=

# ===== Tuning (optional) =====
RATE_LIMIT_CHAT_PER_HOUR=60
LOG_LEVEL=info
CORS_ORIGIN=
