generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String   @unique
  passHash         String   @map("pass_hash")
  locale           String   @default("ar")
  tarsHonesty      Int      @default(90) @map("tars_honesty")
  tarsHumor        Int      @default(60) @map("tars_humor")
  ttsEnabled       Boolean  @default(false) @map("tts_enabled")
  isAdultConfirmed Boolean  @default(false) @map("is_adult_confirmed")
  profile          String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sessions     Session[]
  memoryFacts  MemoryFact[]
  crisisEvents CrisisEvent[]
  metricsLogs  MetricsLog[]
  digests      Digest[]
  ttsUsages    TtsUsage[]

  @@map("users")
}

model Session {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  startedAt DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(6)
  summary   String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, startedAt])
  @@map("sessions")
}

model Message {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String
  persona   String?
  content   String
  emotion   String?
  intensity Int?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  crisisEvents CrisisEvent[]

  @@index([sessionId, createdAt])
  @@map("messages")
}

model MemoryFact {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String                 @map("user_id") @db.Uuid
  fact          String
  category      String // work | health | relations | goals | patterns
  embedding     Unsupported("vector(768)")?
  salience      Float                  @default(1.0)
  lastSeen      DateTime               @default(now()) @map("last_seen") @db.Timestamptz(6)
  sourceMessage String?                @map("source_message") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("memory_facts")
}

model KbEntry {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String                      @unique
  category    String
  nameEn      String                      @map("name_en")
  nameAr      String                      @map("name_ar")
  bodyEn      String                      @map("body_en")
  bodyAr      String                      @map("body_ar")
  techniques  Json
  referWhenEn String                      @map("refer_when_en")
  referWhenAr String                      @map("refer_when_ar")
  sources     Json
  embedding   Unsupported("vector(768)")?

  @@map("kb_entries")
}

model CrisisEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  messageId String?  @map("message_id") @db.Uuid
  trigger   String
  action    String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("crisis_events")
}

model MetricsLog {
  id     Int      @id @default(autoincrement())
  userId String   @map("user_id") @db.Uuid
  source String
  metric String
  value  Float
  day    DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
  @@map("metrics_log")
}

// -- additions beyond the spec SQL (documented in README) --

model Digest {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  weekStart DateTime @map("week_start") @db.Date
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("digests")
}

model TtsUsage {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  chars     Int
  credits   Float
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tts_usage")
}

model TtsCache {
  hash      String   @id
  audio     Bytes
  chars     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("tts_cache")
}
